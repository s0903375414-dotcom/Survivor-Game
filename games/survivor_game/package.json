{
  "name": "survivor-game",
  "version": "1.0.0",
  "description": "Survivor Game Desktop Application",
  "author": "Commander",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder"
  },
  "dependencies": {
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.survivor.game",
    "productName": "Survivor Game Evolution",
    "copyright": "Copyright © 2024 Survivor Team",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "publish": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Survivor Game"
    },
    "files": [
      "**/*",
      "!dist/*",
      "!node_modules/electron/*",
      "!node_modules/electron-builder/*"
    ]
  }
}
